# Telegram bot token from @BotFather (required)
BOT_TOKEN=123456:ABC-DEF...

# Optional: self-hosted Bot API server endpoint (raises upload limit to 2GB)
# TG_API_ENDPOINT=http://localhost:8081/bot

# Optional: HTTP(S) proxy for both YouTube and Telegram access
# PROXY=http://127.0.0.1:7890
# (HTTP_PROXY / HTTPS_PROXY / ALL_PROXY also work)

# Optional: reject songs longer than N minutes (default 12)
MAX_DURATION_MIN=12

# Optional: number of search results to show (default 8, max 20)
SEARCH_LIMIT=8

# Optional: temp directory for downloads (default OS temp)
# DOWNLOAD_DIR=/tmp
